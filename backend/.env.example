# ---- Server ----
NODE_ENV=development              # development | production | test
PORT=4000                         # port the API listens on

# ---- Database ----
# Local Postgres (Docker compose exposes it on localhost:5432)
DATABASE_URL=postgresql://hrms:hrms@localhost:5432/hrms?schema=public

# ---- CORS ----
CORS_ORIGIN=http://localhost:3000 # frontend origin allowed to call the API (never *)

# ---- JWT / Auth ----
JWT_ACCESS_SECRET=change-me-access-secret     # signs 15-min access tokens
JWT_ACCESS_EXPIRES=15m                        # access token lifetime
REFRESH_TOKEN_TTL_DAYS=7                       # refresh token lifetime (default)
REFRESH_TOKEN_TTL_DAYS_REMEMBER=30             # refresh lifetime when "Remember Me"
BCRYPT_COST=12                                 # bcrypt work factor

# ---- Email verification / reset token lifetimes ----
EMAIL_VERIFY_TTL_HOURS=24         # email verification token lifetime
PASSWORD_RESET_TTL_HOURS=1        # password reset token lifetime
EMAIL_RESEND_COOLDOWN_SECONDS=60  # cooldown between verification resends

# ---- SMTP (maildev in dev) ----
SMTP_HOST=localhost               # maildev host (compose: "maildev")
SMTP_PORT=1025                    # maildev SMTP port
SMTP_SECURE=false                 # true only for real TLS SMTP
SMTP_FROM="HRMS <no-reply@hrms.local>"  # From header on outgoing mail

# ---- App URLs (used in email links) ----
APP_WEB_URL=http://localhost:3000 # frontend base URL for verify/reset links

# ---- Org config ----
ORG_TIMEZONE=Asia/Kolkata         # display timezone (storage is always UTC)
HALF_DAY_THRESHOLD_HOURS=4        # worked-hours threshold for HALF_DAY
LEAVE_DEFAULT_PAID=18             # default annual paid leave balance
LEAVE_DEFAULT_SICK=10             # default annual sick leave balance

# ---- Uploads ----
UPLOAD_DIR=src/uploads            # base dir for stored files
MAX_IMAGE_MB=5                    # max image upload size
MAX_DOC_MB=10                     # max document upload size
